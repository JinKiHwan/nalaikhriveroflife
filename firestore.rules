rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function: get user document from users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function: check if user is master
    function isMaster() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'master';
    }
    
    // Helper function: check if user is teacher or master
    function isTeacher() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (getUserData().role == 'teacher' || getUserData().role == 'master');
    }

    // Users Collection
    match /users/{userId} {
      // Authenticated members can read other members' basic profiles (e.g. for listing/comments)
      allow read: if isAuthenticated();
      
      // Allow a user to create/write their own document initially, or if they are created by the Master
      allow create, update: if (isAuthenticated() && request.auth.uid == userId) || isMaster();
      
      // Only Master can delete user documents
      allow delete: if isMaster();
    }

    // Sermons Collection
    match /sermons/{sermonId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    // Notices Collection
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    // Teachers Posts Collection
    match /teachers_posts/{postId} {
      allow read, write: if isTeacher();
    }

    // QT Collection
    match /qt/{qtDate} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
      
      // Comments Subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isMaster() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      }
    }

    // Events Relay Logs Collection
    match /events_bible_relay_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isMaster() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow update: if false; // Logs cannot be updated once created
    }
  }
}
